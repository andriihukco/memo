# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram bot username (without @), e.g. memo_r0bot
TELEGRAM_BOT_USERNAME=

# Miniapp URL — the full URL to your deployed miniapp (used for inline buttons)
MINIAPP_URL=https://project-mb7a5.vercel.app/miniapp

# Webhook secret — set this to a random string (openssl rand -hex 32), then
# register it with Telegram once after deploy:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<URL>&secret_token=<SECRET>"
# Telegram will send X-Telegram-Bot-Api-Secret-Token on every update.
TELEGRAM_WEBHOOK_SECRET=

# ─── Supabase (server-side only) ─────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=

# Service role key — bypasses RLS; used only in webhook, cron, and embedding worker
# NEVER expose this to the client
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Gemini ────────────────────────────────────────────────────────────
# API key for gemini-2.5-flash-lite, gemini-2.5-flash, and gemini-embedding-001
# NEVER expose this to the client
GEMINI_API_KEY=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret used to authenticate calls to /api/cron/process
# Vercel injects this automatically for cron jobs; set it manually for local testing
CRON_SECRET=

# ─── Supabase (client-side / Next.js public) ─────────────────────────────────
# These are safe to expose to the browser — RLS enforces data isolation
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex pepper for entry encryption key derivation
# Generate with: openssl rand -hex 32
ENTRY_ENCRYPTION_PEPPER=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# DSN from your Sentry project → Settings → Client Keys.
# If not set, Sentry is a no-op (no errors are captured).
# Server-side DSN (API routes, bot webhook, cron jobs):
SENTRY_DSN=
# Client-side DSN (browser / Mini App) — safe to expose publicly:
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source-map uploads during build (Vercel CI only):
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# ─── PostHog (optional) ──────────────────────────────────────────────────────
# Project API key from PostHog → Project Settings → Project API Key.
# Safe to expose publicly (it's a write-only ingest key).
# If not set, all analytics calls are no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog ingest host — use your region's endpoint:
#   EU: https://eu.i.posthog.com  (default)
#   US: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
