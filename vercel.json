{
  "framework": "nextjs",
  "functions": {
    "src/app/api/telegram/webhook/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/process/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/reports",
      "schedule": "0 9 * * *"
    }
  ]
}
