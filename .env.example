# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ─── Supabase (server-side only) ─────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=

# Service role key — bypasses RLS; used only in webhook, cron, and embedding worker
# NEVER expose this to the client
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Gemini ────────────────────────────────────────────────────────────
# API key for gemini-2.5-flash-lite, gemini-2.5-flash, and gemini-embedding-001
# NEVER expose this to the client
GEMINI_API_KEY=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret used to authenticate calls to /api/cron/process
# Vercel injects this automatically for cron jobs; set it manually for local testing
CRON_SECRET=

# ─── Supabase (client-side / Next.js public) ─────────────────────────────────
# These are safe to expose to the browser — RLS enforces data isolation
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
